#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_AGENTS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

usage() {
    echo "Usage: job-claim [job-id] [-r <role>] --agent-id <agent-id>"
    echo ""
    echo "Claim a pending job for a named agent."
    echo "If no job-id is given, claims the oldest pending job."
    echo "Returns 'CLAIMED: <job-id>' or 'NO_JOBS'."
    echo ""
    echo "Options:"
    echo "  -r <role>    Only claim jobs assigned to this role"
    echo "  --agent-id   Named agent that will own the job"
    exit 1
}

JOB_ID=""
JOB_ROLE=""
AGENT_ID=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        -r|--role)
            [ "$#" -ge 2 ] || die "$1 requires a role"
            JOB_ROLE="$2"
            shift 2
            ;;
        --agent-id)
            [ "$#" -ge 2 ] || die "$1 requires an agent ID"
            AGENT_ID="$2"
            shift 2
            ;;
        --help|-h)
            usage
            ;;
        *)
            if [ -z "$JOB_ID" ]; then
                JOB_ID="$1"
            else
                die "unexpected argument '$1'"
            fi
            shift
            ;;
    esac
done

[ -n "$JOB_ROLE" ] && validate_role "$JOB_ROLE"
[ -n "$AGENT_ID" ] || die "--agent-id <agent-id> is required"
validate_agent_id "$AGENT_ID"
require_jobs_dir

claim_job() {
    job_id="$1"
    job_dir="$JOBS_DIR/$job_id"

    [ -d "$job_dir" ] || return 1
    [ -f "$job_dir/status" ] || return 1
    [ -f "$job_dir/role" ] || return 1

    status="$(cat "$job_dir/status" 2>/dev/null || true)"
    [ "$status" = "pending" ] || return 1

    role="$(cat "$job_dir/role" 2>/dev/null || true)"
    [ -n "$role" ] || return 1

    if [ -n "$JOB_ROLE" ] && [ "$role" != "$JOB_ROLE" ]; then
        return 1
    fi

    mkdir "$job_dir/lock" 2>/dev/null || return 1

    write_file_atomic "$job_dir/agent-id" "$AGENT_ID"
    write_file_atomic "$job_dir/status" "claimed"
    echo "CLAIMED: $job_id"
    return 0
}

if [ -n "$JOB_ID" ]; then
    validate_job_id "$JOB_ID"
    [ -d "$JOBS_DIR/$JOB_ID" ] || die "job '$JOB_ID' does not exist"

    if claim_job "$JOB_ID"; then
        exit 0
    fi

    status="$(cat "$JOBS_DIR/$JOB_ID/status" 2>/dev/null || echo "unknown")"
    [ "$status" = "pending" ] || die "cannot claim job '$JOB_ID' from status '$status' (expected: pending)"
    [ ! -d "$JOBS_DIR/$JOB_ID/lock" ] || die "cannot claim job '$JOB_ID': lock directory already exists"
    die "could not claim job '$JOB_ID' due to a concurrent claim race"
fi

for job_name in $(ls -1tr "$JOBS_DIR" 2>/dev/null || true); do
    validate_job_id "$job_name"
    if claim_job "$job_name"; then
        exit 0
    fi
done

echo "NO_JOBS"
