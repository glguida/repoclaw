#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_AGENTS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

STALE_MINUTES="${1:-60}"
[ "$#" -le 1 ] || die "unexpected argument '$2'"
require_positive_integer "minutes" "$STALE_MINUTES"
require_jobs_dir

echo "Reaping locks stale for more than ${STALE_MINUTES} minutes..."

now="$(date +%s)"
reaped=0

for job_dir in "$JOBS_DIR"/*; do
    [ -d "$job_dir" ] || continue
    [ -f "$job_dir/status" ] || continue
    [ -d "$job_dir/lock" ] || continue

    job_id="$(basename "$job_dir")"
    status="$(cat "$job_dir/status" 2>/dev/null || true)"

    if stat -c %Y "$job_dir/lock" >/dev/null 2>&1; then
        lock_time="$(stat -c %Y "$job_dir/lock")"
    elif stat -f %m "$job_dir/lock" >/dev/null 2>&1; then
        lock_time="$(stat -f %m "$job_dir/lock")"
    else
        lock_time=0
    fi

    age=$(( (now - lock_time) / 60 ))
    if [ "$age" -ge "$STALE_MINUTES" ]; then
        echo "reaping: $job_id (status: $status, stale for ${age}m)"
        if ! rmdir "$job_dir/lock" 2>/dev/null; then
            echo "error: cannot reap job '$job_id': lock directory is not empty" >&2
            continue
        fi

        case "$status" in
            done|failed)
                append_log "$job_dir" "Removed stale lock" "Removed stale lock from terminal $status job after ${age}m."
                ;;
            *)
                rm -f "$job_dir/agent-id"
                write_file_atomic "$job_dir/status" "pending"
                append_log "$job_dir" "Reaped stale job" "Reset stale $status job after ${age}m."
                ;;
        esac
        reaped=$((reaped + 1))
    fi
done

echo "Reaped $reaped job(s)."
