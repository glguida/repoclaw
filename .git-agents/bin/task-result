#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_AGENTS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

usage() {
    echo "Usage: task-result <task-id> <result-file>"
    exit 1
}

[ "$#" -eq 2 ] || usage

TASK_ID="$1"
RESULT_FILE="$2"

validate_task_id "$TASK_ID"
[ -f "$RESULT_FILE" ] || die "result file '$RESULT_FILE' does not exist"
[ -s "$RESULT_FILE" ] || die "result file '$RESULT_FILE' is empty"
require_tasks_dir

TASK_DIR="$TASKS_DIR/$TASK_ID"

[ -d "$TASK_DIR" ] || die "task '$TASK_ID' does not exist"
cp "$RESULT_FILE" "$TASK_DIR/result.md"
write_file_atomic "$TASK_DIR/state" "done"
append_task_log "$TASK_DIR" "Result recorded" "See result.md. State set to done."

echo "$TASK_ID: result recorded"
echo "$TASK_ID: state -> done"
