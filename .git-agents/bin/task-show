#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_AGENTS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

usage() {
    echo "Usage: task-show <task-id>"
    exit 1
}

[ "$#" -eq 1 ] || usage

TASK_ID="$1"

validate_task_id "$TASK_ID"
require_tasks_dir

TASK_DIR="$TASKS_DIR/$TASK_ID"

[ -d "$TASK_DIR" ] || die "task '$TASK_ID' does not exist"
echo "# Task $TASK_ID"
echo ""
printf 'State: %s\n' "$(cat "$TASK_DIR/state" 2>/dev/null || printf 'open')"
echo ""
echo "## Spec"
cat "$TASK_DIR/spec.md"
echo ""
echo "## Log"
cat "$TASK_DIR/log.md"
if [ -f "$TASK_DIR/result.md" ]; then
    echo ""
    echo "## Result"
    cat "$TASK_DIR/result.md"
fi
