#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_AGENTS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

usage() {
    echo "Usage: job-create <job-id> -r <role> -t <task-id> <spec-file>"
    echo ""
    echo "Create a new job for a role inside a task with a complete spec."
    echo ""
    echo "Options:"
    echo "  -r <role>    Role that should process the job"
    echo "  -t <task-id> Task this job belongs to"
    exit 1
}

JOB_ID=""
JOB_ROLE=""
TASK_ID=""
SPEC_FILE=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        -r|--role)
            [ "$#" -ge 2 ] || die "$1 requires a role"
            JOB_ROLE="$2"
            shift 2
            ;;
        -t|--task-id)
            [ "$#" -ge 2 ] || die "$1 requires a task ID"
            TASK_ID="$2"
            shift 2
            ;;
        --help|-h)
            usage
            ;;
        *)
            if [ -z "$JOB_ID" ]; then
                JOB_ID="$1"
            elif [ -z "$SPEC_FILE" ]; then
                SPEC_FILE="$1"
            else
                die "unexpected argument '$1'"
            fi
            shift
            ;;
    esac
done

[ -z "$JOB_ID" ] && usage
[ -z "$JOB_ROLE" ] && die "job role required (-r <role>)"
[ -z "$TASK_ID" ] && die "task ID required (-t <task-id>)"
[ -z "$SPEC_FILE" ] && die "spec file required"
[ "$SPEC_FILE" = "-" ] && die "pass a spec file path, not stdin"
[ -f "$SPEC_FILE" ] || die "spec file '$SPEC_FILE' does not exist"
[ -s "$SPEC_FILE" ] || die "spec file '$SPEC_FILE' is empty"

validate_job_id "$JOB_ID"
validate_role "$JOB_ROLE"
validate_task_id "$TASK_ID"
require_jobs_dir
require_tasks_dir

[ -d "$TASKS_DIR/$TASK_ID" ] || die "task '$TASK_ID' does not exist"

JOB_DIR="$JOBS_DIR/$JOB_ID"

if ! mkdir "$JOB_DIR" 2>/dev/null; then
    die "job '$JOB_ID' already exists"
fi

mkdir "$JOB_DIR/workspace"
cp "$SPEC_FILE" "$JOB_DIR/spec.md"

write_file_atomic "$JOB_DIR/role" "$JOB_ROLE"
write_file_atomic "$JOB_DIR/task-id" "$TASK_ID"
touch "$JOB_DIR/log.md"
write_file_atomic "$JOB_DIR/status" "pending"

echo "created: $JOB_DIR (task: $TASK_ID, role: $JOB_ROLE)"
echo "spec: $JOB_DIR/spec.md"
