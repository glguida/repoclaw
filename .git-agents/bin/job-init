#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_AGENTS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

if [ -d "$JOBS_DIR" ]; then
    echo "jobs/ directory already exists."
else
    mkdir -p "$JOBS_DIR"
    echo "Created jobs/ directory."
fi

if [ -d "$TASKS_DIR" ]; then
    echo "tasks/ directory already exists."
else
    mkdir -p "$TASKS_DIR"
    echo "Created tasks/ directory."
fi

if [ -d "$AGENTS_DIR" ]; then
    echo "agents/ directory already exists."
else
    mkdir -p "$AGENTS_DIR"
    echo "Created agents/ directory."
fi

echo "GitAgents initialized at: $GIT_AGENTS_ROOT"
echo "GitAgents state at: $GIT_AGENTS_STATE_DIR"
echo ""
echo "Next steps:"
echo "  1. Write a complete task:  \$EDITOR /tmp/my-first-task.md"
echo "  2. Create the task:        bin/task-create my-first-task /tmp/my-first-task.md"
echo "  3. Start a planner:        tools/agent planner planner-1"
