#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_AGENTS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

usage() {
    echo "Usage: job-wait [-r <role>]"
    exit 1
}

JOB_ROLE=""
WAIT_INTERVAL="${GIT_AGENTS_WAIT_INTERVAL:-5}"
require_positive_integer "GIT_AGENTS_WAIT_INTERVAL" "$WAIT_INTERVAL"

while [ "$#" -gt 0 ]; do
    case "$1" in
        -r|--role)
            [ "$#" -ge 2 ] || die "$1 requires a role"
            JOB_ROLE="$2"
            shift 2
            ;;
        --help|-h)
            usage
            ;;
        *)
            die "unknown option '$1'"
            ;;
    esac
done

[ -n "$JOB_ROLE" ] && validate_role "$JOB_ROLE"
require_jobs_dir

has_pending_job() {
    for job_dir in "$JOBS_DIR"/*; do
        [ -d "$job_dir" ] || continue
        [ -f "$job_dir/status" ] || continue
        [ -f "$job_dir/role" ] || continue

        status="$(cat "$job_dir/status" 2>/dev/null || true)"
        [ "$status" = "pending" ] || continue

        role="$(cat "$job_dir/role" 2>/dev/null || true)"
        if [ -n "$JOB_ROLE" ] && [ "$role" != "$JOB_ROLE" ]; then
            continue
        fi

        [ ! -d "$job_dir/lock" ] || continue
        return 0
    done

    return 1
}

while :; do
    if has_pending_job; then
        exit 0
    fi
    sleep "$WAIT_INTERVAL"
done
