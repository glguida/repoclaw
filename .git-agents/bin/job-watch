#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_AGENTS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

usage() {
    echo "Usage: job-watch <status> [--poll <seconds>]"
    exit 1
}

[ "$#" -ge 1 ] || usage

TARGET_STATUS="$1"
shift
require_valid_status "$TARGET_STATUS"

POLL_INTERVAL=5

while [ "$#" -gt 0 ]; do
    case "$1" in
        --poll)
            [ "$#" -ge 2 ] || die "--poll requires seconds"
            POLL_INTERVAL="$2"
            require_positive_integer "--poll" "$POLL_INTERVAL"
            shift 2
            ;;
        --help|-h)
            usage
            ;;
        *)
            die "unknown option '$1'"
            ;;
    esac
done

require_jobs_dir

SEEN_FILE="${TMPDIR:-/tmp}/git_agents-watch.$$"
trap 'rm -f "$SEEN_FILE"' EXIT HUP INT TERM
: > "$SEEN_FILE"

while :; do
    for job_dir in "$JOBS_DIR"/*; do
        [ -d "$job_dir" ] || continue
        [ -f "$job_dir/status" ] || continue

        job_id="$(basename "$job_dir")"
        status="$(cat "$job_dir/status" 2>/dev/null || true)"

        if [ "$status" = "$TARGET_STATUS" ]; then
            if ! grep -x "$job_id" "$SEEN_FILE" >/dev/null 2>&1; then
                printf '[%s] %s -> %s\n' "$(timestamp)" "$job_id" "$TARGET_STATUS"
                printf '%s\n' "$job_id" >> "$SEEN_FILE"
            fi
        else
            if grep -x "$job_id" "$SEEN_FILE" >/dev/null 2>&1; then
                grep -x -v "$job_id" "$SEEN_FILE" > "$SEEN_FILE.tmp" 2>/dev/null || true
                mv "$SEEN_FILE.tmp" "$SEEN_FILE"
            fi
        fi
    done

    sleep "$POLL_INTERVAL"
done
