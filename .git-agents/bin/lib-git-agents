#!/bin/sh
# SPDX-License-Identifier: MIT

GIT_AGENTS_STATE_DIR="${GIT_AGENTS_STATE_DIR:-$GIT_AGENTS_ROOT/state}"
JOBS_DIR="${JOBS_DIR:-$GIT_AGENTS_STATE_DIR/jobs}"
TASKS_DIR="${TASKS_DIR:-$GIT_AGENTS_STATE_DIR/tasks}"
AGENTS_DIR="${AGENTS_DIR:-$GIT_AGENTS_STATE_DIR/agents}"
VALID_STATUSES="${VALID_STATUSES:-pending claimed running done failed}"
VALID_TASK_STATES="${VALID_TASK_STATES:-open done}"

die() {
    echo "error: $*" >&2
    exit 1
}

timestamp() {
    date -u +%Y-%m-%dT%H:%M:%SZ
}

agent_host() {
    hostname 2>/dev/null || uname -n
}

validate_name() {
    label="$1"
    value="${2:-}"

    case "$value" in
        ""|*[!A-Za-z0-9._-]*)
            die "invalid $label '$value' - only alphanumeric, dot, underscore, and hyphen allowed"
            ;;
    esac
}

is_safe_name() {
    value="${1:-}"

    case "$value" in
        ""|*[!A-Za-z0-9._-]*)
            return 1
            ;;
    esac

    return 0
}

validate_job_id() {
    validate_name "job ID" "${1:-}"
}

validate_task_id() {
    validate_name "task ID" "${1:-}"
}

validate_role() {
    validate_name "role" "${1:-}"
}

validate_agent_id() {
    validate_name "agent ID" "${1:-}"
}

is_valid_status() {
    candidate="${1:-}"

    for status in $VALID_STATUSES; do
        [ "$status" = "$candidate" ] && return 0
    done

    return 1
}

require_valid_status() {
    status="${1:-}"

    if ! is_valid_status "$status"; then
        echo "error: invalid status '$status'" >&2
        echo "valid statuses: $VALID_STATUSES" >&2
        exit 1
    fi
}

is_valid_task_state() {
    candidate="${1:-}"

    for state in $VALID_TASK_STATES; do
        [ "$state" = "$candidate" ] && return 0
    done

    return 1
}

require_valid_task_state() {
    state="${1:-}"

    if ! is_valid_task_state "$state"; then
        echo "error: invalid task state '$state'" >&2
        echo "valid task states: $VALID_TASK_STATES" >&2
        exit 1
    fi
}

require_jobs_dir() {
    [ -d "$JOBS_DIR" ] || die "jobs directory '$JOBS_DIR' does not exist; run bin/job-init first"
}

require_tasks_dir() {
    [ -d "$TASKS_DIR" ] || die "tasks directory '$TASKS_DIR' does not exist; run bin/job-init first"
}

require_positive_integer() {
    name="$1"
    value="${2:-}"

    case "$value" in
        ""|*[!0-9]*)
            die "$name must be a positive integer"
            ;;
    esac

    [ "$value" -gt 0 ] || die "$name must be greater than zero"
}

read_status() {
    job_dir="$1"
    cat "$job_dir/status" 2>/dev/null || echo "unknown"
}

write_file_atomic() {
    path="$1"
    content="$2"
    tmp="$path.tmp.$$"

    printf '%s\n' "$content" > "$tmp" || die "cannot write temporary file '$tmp'"
    mv -f "$tmp" "$path" || {
        rm -f "$tmp"
        die "cannot replace '$path'"
    }
}

clear_agent_current_job() {
    agent_id="${1:-}"
    job_id="${2:-}"

    is_safe_name "$agent_id" || return 0
    [ -n "$job_id" ] || return 0

    current_file="$AGENTS_DIR/$agent_id/current-job"
    [ -f "$current_file" ] || return 0

    current="$(cat "$current_file" 2>/dev/null || true)"
    if [ "$current" = "$job_id" ]; then
        write_file_atomic "$current_file" ""
    fi
}

remove_job_lock() {
    job_id="$1"
    job_dir="$2"
    force="${3:-0}"

    [ -d "$job_dir/lock" ] || return 0

    if rmdir "$job_dir/lock" 2>/dev/null; then
        return 0
    fi

    if [ "$force" = "1" ]; then
        rm -rf "$job_dir/lock" || die "cannot remove lock directory for job '$job_id'"
        return 0
    fi

    die "cannot remove lock directory for job '$job_id': lock directory is not empty; retry with --force"
}

require_agent_owner() {
    action="$1"
    job_id="$2"
    job_dir="$3"
    agent_id="$4"

    validate_agent_id "$agent_id"
    [ -f "$job_dir/agent-id" ] || die "cannot $action job '$job_id': missing agent-id"
    expected="$(cat "$job_dir/agent-id" 2>/dev/null || true)"

    if [ "$expected" != "$agent_id" ]; then
        die "cannot $action job '$job_id': owned by '$expected', not '$agent_id'"
    fi
}

append_log() {
    job_dir="$1"
    summary="$2"
    detail="${3:-}"

    {
        printf '## %s - %s\n\n' "$(timestamp)" "$summary"
        if [ -n "$detail" ]; then
            printf '%s\n\n' "$detail"
        fi
    } >> "$job_dir/log.md"
}

append_task_log() {
    task_dir="$1"
    summary="$2"
    detail="${3:-}"

    {
        printf '## %s - %s\n\n' "$(timestamp)" "$summary"
        if [ -n "$detail" ]; then
            printf '%s\n\n' "$detail"
        fi
    } >> "$task_dir/log.md"
}
