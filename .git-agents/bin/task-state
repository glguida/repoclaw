#!/bin/sh
# SPDX-License-Identifier: MIT
set -eu

GIT_AGENTS_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
. "$GIT_AGENTS_ROOT/bin/lib-git-agents"

usage() {
    echo "Usage: task-state <task-id> <open|done> [-m <message>]"
    exit 1
}

TASK_ID=""
STATE=""
MESSAGE=""

while [ "$#" -gt 0 ]; do
    case "$1" in
        -m)
            [ "$#" -ge 2 ] || die "-m requires a message"
            MESSAGE="$2"
            shift 2
            ;;
        --help|-h)
            usage
            ;;
        *)
            if [ -z "$TASK_ID" ]; then
                TASK_ID="$1"
            elif [ -z "$STATE" ]; then
                STATE="$1"
            else
                die "unexpected argument '$1'"
            fi
            shift
            ;;
    esac
done

[ -n "$TASK_ID" ] || usage
[ -n "$STATE" ] || usage

validate_task_id "$TASK_ID"
require_valid_task_state "$STATE"
require_tasks_dir

TASK_DIR="$TASKS_DIR/$TASK_ID"

[ -d "$TASK_DIR" ] || die "task '$TASK_ID' does not exist"
write_file_atomic "$TASK_DIR/state" "$STATE"
append_task_log "$TASK_DIR" "State: $STATE" "$MESSAGE"

echo "$TASK_ID: state -> $STATE"
