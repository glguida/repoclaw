#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
"""Send one message to the running GitAgents console agent."""

from __future__ import annotations

import argparse
import os
import sys
from pathlib import Path

from console_input import send_console_input


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Send one message to the GitAgents console agent.")
    parser.add_argument(
        "--state-dir",
        default=os.environ.get("GIT_AGENTS_STATE_DIR", ".git-agents/state"),
        help="GitAgents state directory. Defaults to GIT_AGENTS_STATE_DIR or .git-agents/state.",
    )
    parser.add_argument("--mode", choices=["prompt", "follow_up", "steer"], default="prompt")
    parser.add_argument("message", nargs="*")
    return parser.parse_args()


def main() -> int:
    args = parse_args()
    if args.message:
        message = " ".join(args.message)
    elif not sys.stdin.isatty():
        message = sys.stdin.read()
    else:
        print("error: message required", file=sys.stderr)
        return 1
    message = message.rstrip()
    if not message:
        print("error: message required", file=sys.stderr)
        return 1
    return 0 if send_console_input(Path(args.state_dir).resolve(), message, args.mode) else 1


if __name__ == "__main__":
    raise SystemExit(main())
