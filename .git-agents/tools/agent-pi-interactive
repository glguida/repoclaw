#!/usr/bin/env python3
# SPDX-License-Identifier: MIT
"""Run one named GitAgents interactive agent with live browser input."""

from __future__ import annotations

import argparse
import importlib.machinery
import importlib.util
import json
import os
import shutil
import signal
import stat
import subprocess
import sys
import threading
import time
from pathlib import Path
from typing import Any


SCRIPT_DIR = Path(__file__).resolve().parent
ROOT = SCRIPT_DIR.parent


def load_agent_module():
    loader = importlib.machinery.SourceFileLoader("git_agents_agent", str(SCRIPT_DIR / "agent"))
    spec = importlib.util.spec_from_loader(loader.name, loader)
    if spec is None:
        raise RuntimeError("cannot load GitAgents agent runtime module")
    module = importlib.util.module_from_spec(spec)
    loader.exec_module(module)
    return module


agent_mod = load_agent_module()


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(description="Run one named interactive GitAgents agent.")
    engine = parser.add_mutually_exclusive_group()
    engine.add_argument("--pi", action="store_const", const="pi", dest="engine")
    parser.set_defaults(engine="pi")
    parser.add_argument("--console", action="store_true", help="run the built-in GitAgents console agent")
    parser.add_argument("--headless", action="store_true", help="Do not mirror rendered transcript output to stdout")
    parser.add_argument("-m", "--model")
    parser.add_argument("role", nargs="?")
    parser.add_argument("agent_name", nargs="?")
    args = parser.parse_args()
    if args.console:
        args.role = args.role or "console"
        args.agent_name = args.agent_name or "console"
    elif not args.role or not args.agent_name:
        parser.error("role and agent_name are required unless --console is used")
    return args


def ensure_fifo(path: Path) -> None:
    try:
        mode = path.stat().st_mode
        if stat.S_ISFIFO(mode):
            return
        path.unlink()
    except FileNotFoundError:
        pass
    os.mkfifo(path, 0o600)


def write_json_line(stream, value: dict[str, Any], lock: threading.Lock) -> bool:
    with lock:
        if stream.closed:
            return False
        try:
            stream.write(json.dumps(value) + "\n")
            stream.flush()
            return True
        except BrokenPipeError:
            return False


def read_job_status(job_dir: Path) -> str:
    try:
        return (job_dir / "status").read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def read_job_owner(job_dir: Path) -> str:
    try:
        return (job_dir / "agent-id").read_text(encoding="utf-8").strip()
    except OSError:
        return ""


def has_pi_session_history(session_dir: Path) -> bool:
    if not session_dir.is_dir():
        return False
    try:
        for path in session_dir.rglob("*"):
            if path.is_file() and not path.name.endswith(".lock"):
                return True
    except OSError:
        return False
    return False


def build_pi_rpc_command(
    model: str | None,
    console: bool,
    prompt: str,
    session_dir: Path,
) -> list[str]:
    command = ["pi", "--mode", "rpc"]
    if model:
        command.extend(["--model", model])
    if console:
        command.extend(["--append-system-prompt", prompt])
    command.extend(["--session-dir", str(session_dir)])
    if console and has_pi_session_history(session_dir):
        command.append("--continue")
    return command


def rpc_streaming_state(event: dict[str, Any]) -> bool | None:
    typ = event.get("type")
    if typ in ("agent_start", "turn_start"):
        return True
    if typ in ("agent_end", "turn_end"):
        return False
    return None


def file_has_content(path: Path) -> bool:
    try:
        return path.stat().st_size > 0
    except OSError:
        return False


def restart_context(
    transcript_path: Path | None,
    include_restart_context: bool,
    crash_path: Path | None,
) -> str:
    if not transcript_path or not include_restart_context:
        return ""
    parts = [
        "This console has an existing transcript from a previous run. This is a restart, not a fresh conversation.",
        f"Before answering after this restart, read enough recent history from {transcript_path} to recover the conversation context. Do not start bootstrap or identity discovery from scratch unless the transcript shows it is still incomplete.",
    ]
    if crash_path and crash_path.is_file():
        parts.append(
            f"The previous Pi process crashed during an active turn. Read {crash_path} and the transcript, then continue if possible; if the lost turn cannot be recovered, ask the human to resend it."
        )
    return "\n".join(parts)


def recovery_prompt(transcript_path: Path, crash_path: Path) -> str:
    return (
        "Recover after an interactive console restart. "
        f"Read the recent conversation in {transcript_path}. "
        f"Also read the crash marker at {crash_path}. "
        "Do not start bootstrap or identity discovery from scratch unless the transcript shows it is still incomplete. "
        "If you can continue the interrupted turn from the transcript, do so. "
        "If the lost turn cannot be recovered, tell the human that the previous turn crashed and ask them to resend the missing request."
    )


def build_prompt(
    agent_name: str,
    console: bool,
    root: Path,
    repo_root: Path | None = None,
    job_id: str = "",
    transcript_path: Path | None = None,
    include_restart_context: bool = False,
    crash_path: Path | None = None,
) -> str:
    rules_path = agent_mod.protocol_path(root, repo_root)
    state_root = agent_mod.state_dir(root)
    if not console:
        return "\n".join(
            part
            for part in (
                f"You are agent {agent_name}.",
                f"Your GitAgents root is: {root}",
                f"Your GitAgents state directory is: {state_root}",
                f"Your target repository root is: {repo_root}" if repo_root else "",
                f"Your assigned job is: {job_id}" if job_id else "",
                (
                    f"Read {rules_path} before working. It is the GitAgents-owned "
                    "generic protocol installed by `git agents init` "
                    "and refreshed with `git agents update`. "
                    f"Use the GitAgents command helpers under {root / 'bin'}."
                ),
                "Treat bin/ and roles/ as relative to the GitAgents root. Treat tasks/, jobs/, agents/, runs/, and logs/ as relative to the GitAgents state directory.",
            )
            if part
        )
    role_path = root / "roles" / "console.md"
    restart_text = restart_context(transcript_path, include_restart_context, crash_path)
    return f"""You are agent {agent_name}.

You are the GitAgents console. You interact directly with a human.
Your GitAgents root is: {root}
Your GitAgents state directory is: {state_root}
{"Your target repository root is: " + str(repo_root) if repo_root else ""}
Read {rules_path} before inspecting or changing GitAgents state. It is the GitAgents-owned generic protocol installed by `git agents init` and refreshed with `git agents update`.
Read {role_path} for your console role instructions.
Use the GitAgents command helpers under {root / 'bin'}.
Treat bin/ and roles/ as relative to the GitAgents root. Treat tasks/, jobs/, agents/, runs/, and logs/ as relative to the GitAgents state directory.
{restart_text}
"""


def main() -> int:
    args = parse_args()
    agent_mod.validate_name("role", args.role)
    agent_mod.validate_name("agent ID", args.agent_name)

    if shutil.which(args.engine) is None:
        agent_mod.die(f"required command not found: {args.engine}")

    role_file = ROOT / "roles" / f"{args.role}.md"
    if not role_file.is_file():
        agent_mod.die(f"role file not found: roles/{args.role}.md")

    agent_dir_out = agent_mod.run_bin(ROOT, "agent-new", args.agent_name, args.role).stdout.strip()
    if not agent_dir_out:
        agent_mod.die("agent-new returned no agent directory")
    agent_dir = Path(agent_dir_out)

    agent_mod.write_file(agent_dir / "engine", f"{args.engine}-interactive")
    agent_mod.write_file(agent_dir / "interactive", "1")
    if args.model:
        agent_mod.write_file(agent_dir / "model", args.model)
    agent_mod.write_file(agent_dir / "last_started_at", agent_mod.timestamp())
    agent_mod.write_runtime_pids(agent_dir)

    job_id = ""
    job_dir: Path | None = None
    if args.console:
        agent_mod.write_file(agent_dir / "current-job", "")
    else:
        while True:
            agent_mod.run_bin(ROOT, "job-wait", "-r", args.role, capture=True)
            claim = agent_mod.run_bin(
                ROOT,
                "job-claim",
                "-r",
                args.role,
                "--agent-id",
                args.agent_name,
            ).stdout.strip()
            if claim.startswith("CLAIMED: "):
                job_id = claim.removeprefix("CLAIMED: ").strip()
                break
            if claim == "NO_JOBS":
                continue
            agent_mod.die(f"unexpected job-claim output: {claim}")

        agent_mod.write_file(agent_dir / "current-job", job_id)
        job_dir = agent_mod.state_dir(ROOT) / "jobs" / job_id
        agent_mod.write_runtime_pids(agent_dir, job_dir)

    agent_transcript = agent_dir / "transcript.log"
    agent_error = agent_dir / "error.log"
    agent_busy = agent_dir / "busy"
    last_crash = agent_dir / "last-crash"
    had_transcript = file_has_content(agent_transcript)

    repo_root = agent_mod.read_repo_root(ROOT)
    prompt = build_prompt(
        args.agent_name,
        args.console,
        ROOT,
        repo_root,
        job_id,
        transcript_path=agent_transcript,
        include_restart_context=args.console and had_transcript,
        crash_path=last_crash,
    )
    agent_mod.write_file(agent_dir / "prompt.md", prompt)

    agent_transcript.touch()
    agent_error.touch()
    agent_mod.write_file(agent_busy, "0\n")

    input_fifo = agent_dir / "input.fifo"
    ensure_fifo(input_fifo)
    fifo_anchor = os.open(input_fifo, os.O_RDWR | os.O_NONBLOCK)

    if job_dir is not None:
        agent_mod.append_job_log(
            job_dir,
            "Interactive transcript",
            f"Agent transcript: agents/{args.agent_name}/transcript.log\n"
            f"Interactive input: agents/{args.agent_name}/input.fifo",
        )

    transcript = agent_mod.Transcript(
        [agent_transcript],
        mirror_stdout=not args.headless,
        mirror_prefix=f"{args.agent_name}: ",
    )
    error_files = [agent_error.open("a", encoding="utf-8", buffering=1)]

    proc: subprocess.Popen[str] | None = None
    proc_lock = threading.Lock()
    stop_event = threading.Event()
    is_streaming = threading.Event()
    stdin_lock = threading.Lock()
    shutdown_signals = (signal.SIGTERM, signal.SIGINT)
    previous_handlers = {signum: signal.getsignal(signum) for signum in shutdown_signals}

    def request_shutdown(signum: int, _frame: Any) -> None:
        stop_event.set()
        raise agent_mod.ShutdownRequested(signum)

    def set_streaming(active: bool) -> None:
        if active:
            is_streaming.set()
        else:
            is_streaming.clear()
        agent_mod.write_file(agent_busy, "1\n" if active else "0\n")

    def transcript_user_message(message: str) -> None:
        transcript.heading("User")
        transcript.write(message.rstrip() + "\n")

    def write_error_line(line: str) -> None:
        for f in error_files:
            f.write(line)
            f.flush()
        prefix = f"{args.agent_name}: "
        sys.stderr.write(prefix + line)
        sys.stderr.flush()

    try:
        for signum in shutdown_signals:
            signal.signal(signum, request_shutdown)

        transcript.event(
            "interactive run start",
            "\n".join(
                part
                for part in (
                    f"agent: {args.agent_name}",
                    f"role: {args.role}",
                    f"job: {job_id}" if job_id else "",
                    f"engine: {args.engine}-interactive",
                    "mode: console" if args.console else "",
                    f"model: {args.model}" if args.model else "",
                    f"input: agents/{args.agent_name}/input.fifo",
                )
                if part
            ),
        )

        def watch_job_status() -> None:
            while not stop_event.is_set():
                time.sleep(1)
                status_value = read_job_status(job_dir)
                owner = read_job_owner(job_dir)
                if status_value not in {"claimed", "running"} or (owner and owner != args.agent_name):
                    transcript.event("interactive run closing", f"job status: {status_value or 'missing'}")
                    stop_event.set()
                    with proc_lock:
                        active_proc = proc
                    if active_proc is not None and active_proc.poll() is None:
                        active_proc.terminate()
                    return

        if args.engine == "pi":
            command = build_pi_rpc_command(args.model, args.console, prompt, agent_dir / "pi-session")

            proc = subprocess.Popen(
                command,
                cwd=ROOT,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                encoding="utf-8",
                errors="replace",
                bufsize=1,
                start_new_session=True,
            )
            agent_mod.write_runtime_pids(agent_dir, job_dir, proc)
            assert proc.stdin is not None
            assert proc.stdout is not None
            assert proc.stderr is not None

            def copy_stderr() -> None:
                assert proc is not None and proc.stderr is not None
                for line in proc.stderr:
                    write_error_line(line)

            def read_rpc_stdout() -> None:
                renderer = agent_mod.Renderer(transcript, "pi")
                assert proc is not None and proc.stdout is not None
                for raw in proc.stdout:
                    try:
                        event = json.loads(raw)
                    except json.JSONDecodeError:
                        renderer.render_line(raw)
                        continue
                    if isinstance(event, dict):
                        streaming_state = rpc_streaming_state(event)
                        if streaming_state is not None:
                            set_streaming(streaming_state)
                            if not streaming_state:
                                agent_mod.remove_file(last_crash)
                        typ = event.get("type")
                        if typ == "response" and event.get("success") is False:
                            transcript.event("pi rpc error", str(event.get("error") or event))
                            continue
                    renderer.render_line(raw)

            def read_browser_input() -> None:
                assert proc is not None and proc.stdin is not None
                while not stop_event.is_set():
                    with input_fifo.open("r", encoding="utf-8") as fifo:
                        for line in fifo:
                            if stop_event.is_set():
                                return
                            try:
                                payload = json.loads(line)
                            except json.JSONDecodeError:
                                transcript.event("interactive input ignored", "invalid JSON")
                                continue
                            message = str(payload.get("message") or "").strip()
                            if not message:
                                continue
                            mode = payload.get("mode") or "follow_up"
                            if mode not in {"follow_up", "steer", "prompt"}:
                                mode = "follow_up"
                            if mode == "steer":
                                command_type = "steer"
                            elif is_streaming.is_set():
                                command_type = "follow_up"
                            else:
                                command_type = "prompt"
                            transcript_user_message(message)
                            if command_type in {"prompt", "follow_up"}:
                                set_streaming(True)
                            elif command_type == "steer":
                                set_streaming(False)
                            sent = write_json_line(
                                proc.stdin,
                                {"id": f"web-{time.time_ns()}", "type": command_type, "message": message},
                                stdin_lock,
                            )
                            if not sent:
                                set_streaming(False)

            stderr_thread = threading.Thread(target=copy_stderr, daemon=True)
            stdout_thread = threading.Thread(target=read_rpc_stdout, daemon=True)
            input_thread = threading.Thread(target=read_browser_input, daemon=True)
            threads = [stderr_thread, stdout_thread, input_thread]
            if job_dir is not None:
                threads.append(threading.Thread(target=watch_job_status, daemon=True))
            for thread in threads:
                thread.start()

            if args.console and last_crash.is_file():
                set_streaming(True)
                recovery = recovery_prompt(agent_transcript, last_crash)
                if not write_json_line(
                    proc.stdin,
                    {"id": "restart-recovery", "type": "prompt", "message": recovery},
                    stdin_lock,
                ):
                    set_streaming(False)
            elif not args.console:
                set_streaming(True)
                if not write_json_line(proc.stdin, {"id": "initial", "type": "prompt", "message": prompt}, stdin_lock):
                    set_streaming(False)

            while proc.poll() is None and not stop_event.is_set():
                time.sleep(0.2)

            stop_event.set()
            if proc.poll() is None:
                agent_mod.terminate_process(proc, timeout=5)
            rc = proc.returncode if proc.returncode is not None else 1
            was_streaming_at_exit = is_streaming.is_set()
            if rc != 0:
                crash_detail = "\n".join(
                    (
                        f"exit: {rc}",
                        f"active_turn: {'yes' if was_streaming_at_exit else 'no'}",
                        f"transcript: {agent_transcript}",
                    )
                )
                if was_streaming_at_exit:
                    transcript.event("interactive turn crashed", crash_detail)
                    agent_mod.write_file(last_crash, crash_detail)
                else:
                    transcript.event("interactive process exited nonzero", crash_detail)
            elif not was_streaming_at_exit:
                agent_mod.remove_file(last_crash)
            transcript.event("interactive run end", f"exit: {rc}")
            return rc

        raise AssertionError(args.engine)
    except agent_mod.ShutdownRequested as exc:
        transcript.event("interactive run interrupted", f"signal: {exc.signum}")
        return 128 + exc.signum
    finally:
        for signum, handler in previous_handlers.items():
            signal.signal(signum, handler)
        stop_event.set()
        agent_mod.write_file(agent_busy, "0\n")
        if proc is not None and proc.poll() is None:
            agent_mod.terminate_process(proc)
        if (
            job_dir is not None
            and read_job_status(job_dir) in {"claimed", "running"}
            and read_job_owner(job_dir) == args.agent_name
        ):
            subprocess.run(
                [
                    str(ROOT / "bin" / "job-release"),
                    job_id,
                    "--agent-id",
                    args.agent_name,
                    "-m",
                    "Interactive agent process exited while the job was still owned by this agent; releasing back to pending.",
                ],
                cwd=ROOT,
                text=True,
                stdout=subprocess.DEVNULL,
                stderr=subprocess.DEVNULL,
                check=False,
            )
        try:
            os.close(fifo_anchor)
        except OSError:
            pass
        try:
            input_fifo.unlink()
        except OSError:
            pass
        agent_mod.clear_runtime_pids(agent_dir, job_dir)
        transcript.close()
        for f in error_files:
            f.close()


if __name__ == "__main__":
    raise SystemExit(main())
